{
  "name": "dfg_3dviewer",
  "version": "1.0.2",
  "lockfileVersion": 3,
  "requires": true,
  "description": "Three.js based DFG 3D Viewer",
  "keywords": [
    "typescript",
    "javascript"
  ],
  "source": "index.html",
  "type": "module",
  "targets": {
    "default": {
      "outputFormat": "esmodule",
      "distDir": "dist"
    }
  },
  "packages": {},
  "devDependencies": {
    "@jsxtools/rollup-plugin-copy": "^0.3.1",
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-url": "^8.0.2",
    "@types/node": "^25.0.6",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "http-server": "^14.1.1",
    "parcel": "^2.16.1",
    "postcss": "^8.5.6",
    "process": "^0.11.10",
    "rollup": "^4.52.5",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-ignore": "^1.0.10",
    "rollup-plugin-lightningcss": "^1.0.0",
    "serve": "^14.2.6"
  },
  "scripts": {
    "dev": "pnpm run dev",
    "dev:test": "cross-env BUILD_SOURCE=IIIF BUILD=test parcel index.html --port 1234",
    "dev:dev": "cross-env BUILD_SOURCE='' BUILD=test parcel index.html --port 1234",
    "dev:prod": "cross-env BUILD_SOURCE='' BUILD=prod parcel index.html --port 1234",
    "build:test": "cross-env BUILD_SOURCE='' BUILD=test rollup -c",
    "build:dev": "cross-env BUILD_SOURCE='IIIF' BUILD=dev rollup -c",
    "build:prod": "cross-env BUILD_SOURCE='' BUILD=prod rollup -c",
    "build:drupal": "node ./scripts/build-drupal.js",
    "build:drupal:custom": "cross-env BUILD_SOURCE='' BUILD=drupal MODULE_CUSTOM=/custom rollup -c",
    "serve:dist": "cross-env BUILD=test serve dist",
    "test:local": "sh ./scripts/run-local-tests.sh",
    "watch": "cross-env BUILD_SOURCE=IIIF BUILD=test rollup -c -w",
    "pack-dist": "node ./scripts/pack-dist.js",
    "dev:tauri": "npm run build:dev && npx serve ./dist/dev -l 1234",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:dev:all": "concurrently \"npm run dev:tauri\" \"tauri dev\""
  },
  "files": [
    "dist/**"
  ],
  "dependencies": {
    "@iiif/3d-manifesto-dev": "^0.7.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "jquery": "^3.7.1",
    "lru-cache": "^11.2.2",
    "playwright": "^1.58.2",
    "pnpm": "^10.33.0",
    "stats.js": "^0.17.0",
    "three": "^0.184.0",
    "toastify-js": "^1.12.0",
    "web-ifc": "^0.0.74"
  }
}
